# ================================
# Blog Auto-Agent 환경변수 템플릿
# 이 파일을 .env 로 복사 후 실제 값 입력
# cp .env.sample .env
# ================================

# [필수] GitHub Token (repo + workflow 권한)
BLOG_GITHUB_TOKEN=your_github_token_here

# [필수] Google Gemini API Key
GEMINI_API_KEY=your_gemini_api_key_here

# [선택] Anthropic Claude API Key
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# [필수] 발행 대상 GitHub 저장소 (owner/repo 형식)
BLOG_REPO=your_github_username/your_repo_name

# [선택] Gmail 알림
GMAIL_USER=your_gmail@gmail.com
GMAIL_APP_PASSWORD=your_gmail_app_password

# [동작 모드] true: 발행 전 수동 승인 / false: 완전 자동
HUMAN_GATE=false

# [인코딩] Windows 환경 한글 깨짐 방지
PYTHONUTF8=1
PYTHONIOENCODING=utf-8
